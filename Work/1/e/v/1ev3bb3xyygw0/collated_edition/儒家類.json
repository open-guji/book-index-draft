    {
      "title": "賈子九卷",
      "level": 3,
      "type": "书",
      "content": "賈子九卷。漢賈誼傳本七十二篇劉向刪定為五十八篇隋唐皆九卷今别本或為十卷",
      "work_id": "1evcmnc5kxbls"
    },
