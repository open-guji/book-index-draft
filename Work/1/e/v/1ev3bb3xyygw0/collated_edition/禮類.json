    {
      "title": "開元禮京兆義羅十卷",
      "level": 3,
      "type": "书",
      "content": "開元禮京兆義羅十卷。不著撰人名氏據開元已有義鑑申衍其說今此又網羅其遺墜云",
      "work_id": "1evcs0hmr88ow"
    },
    {
      "title": "開元禮類釋二十卷",
      "level": 3,
      "type": "书",
      "content": "開元禮類釋二十卷。不著撰人名氏以唐禮繁重故彚其名物粗爲申釋",
      "work_id": "1evcs0hn0a4g0"
    },
    {
      "title": "開元禮一百五十卷",
      "level": 3,
      "type": "书",
      "content": "開元禮一百五十卷",
      "work_id": "1evcs0hm9qy9s"
    },
    {
      "title": "開元禮義鑑一百卷",
      "level": 3,
      "type": "书",
      "content": "開元禮義鑑一百卷。唐蕭嵩撰既定開元禮又以禮家名物繁夥更取歴代沿革隨文釋義與禮並行",
      "work_id": "31hyr5d6d6wwq"
    },
    {
      "title": "開元禮旨問二卷",
      "level": 3,
      "type": "书",
      "content": "開元禮旨問二卷",
      "work_id": "31hyr5d6d6wwr"
    },
    {
      "title": "五禮精義十卷",
      "level": 3,
      "type": "书",
      "content": "五禮精義十卷。唐太常博士韋〈彤〉撰首載唐禮叅引古義申釋其文",
      "work_id": "1evcsw6ib0934"
    },
    {
      "title": "續曲䑓禮三十卷",
      "level": 3,
      "type": "书",
      "content": "續曲䑓禮三十卷",
      "work_id": "31hyr5d6d6wws"
    },
    {
      "title": "禮略十卷",
      "level": 3,
      "type": "书",
      "content": "禮略十卷。唐京兆府櫟陽尉杜肅撰採古經義下逮當世槩舉沿革附禮見文以其言約旨詳故自題略云",
      "work_id": "1evc5pd3nu9z4"
    },
    {
      "title": "禮粹二十卷",
      "level": 3,
      "type": "书",
      "content": "禮粹二十卷。唐寕州叅軍張頻纂凡一百二十五條直鈔崔氏義宗之說無他異聞",
      "work_id": "31hyr5d6d6wwt"
    },
    {
      "title": "開寳通禮二百卷",
      "level": 3,
      "type": "书",
      "content": "開寳通禮二百卷",
      "work_id": "31hyr5d6d6wwu"
    },
    {
      "title": "開寳通禮義纂一百卷（闕）",
      "level": 3,
      "type": "书",
      "content": "開寳通禮義纂一百卷（闕）。皇朝翰林學士盧多遜等撰多遜既定新禮復因開元禮義鑑增益爲開寳通禮義纂一百卷上之詔與通禮並行",
      "work_id": "31hyr5d6d6wwv"
    },
    {
      "title": "五服志三卷",
      "level": 3,
      "type": "书",
      "content": "五服志三卷。不著撰人名氏據江都開元二禮叅引先儒所論輕重之制盖唐人所紬次云",
      "work_id": "1evcsxh4djlkw"
    },
    {
      "title": "春秋諡法一卷",
      "level": 3,
      "type": "书",
      "content": "春秋諡法一卷。不著撰人名氏其法差多于周公諡法",
      "work_id": "31hyr5d6d6www"
    },
    {
      "title": "周公諡法一卷",
      "level": 3,
      "type": "书",
      "content": "周公諡法一卷。不著撰人名氏諡法始于周學者錄之因託以名篇",
      "work_id": "1evcsw9gyqf40"
    },
    {
      "title": "諡例十卷",
      "level": 3,
      "type": "书",
      "content": "諡例十卷",
      "work_id": "31hyr5d6d6wwx"
    },
    {
      "title": "諡法十卷",
      "level": 3,
      "type": "书",
      "content": "諡法十卷。梁賀琛撰初約本周公之諡法至琛又分君臣羙惡婦人之諡各以其類標其目曰舊諡者周公之諡法曰廣諡者約所撰也曰新諡者琛所增也 按永樂大典引此作諡法四卷文獻通考亦同",
      "work_id": "1evcpjot52ups"
    },
    {
      "title": "續古今諡法十四卷",
      "level": 3,
      "type": "书",
      "content": "續古今諡法十四卷。唐户部郎中王彦威撰因舊諡品援集故事依沈約諡例記梁已來至唐得諡官稱姓名又以單複諡爲别",
      "work_id": "1evcsw9irz0n4"
    }
  ]
