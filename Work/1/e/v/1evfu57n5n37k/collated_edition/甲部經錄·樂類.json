  "sections": [
    {
      "title": "甲部經錄·樂類",
      "level": 2,
      "type": "结语",
      "content": "右樂類,存四家,四部。"
    },
    {
      "title": "琴操三卷",
      "level": 3,
      "type": "书",
      "content": "孔衍。謹按見《隋志》。《新唐志》作“一卷”。",
      "work_id": "1evfugvl9z1ts"
    },
    {
      "title": "樂論",
      "level": 3,
      "type": "书",
      "content": "阮籍。謹按見《御覽》引書綱目。《漢書·五行志》注亦引。",
      "work_id": "1evcpctt7ld6o"
    },
    {
      "title": "樂論",
      "level": 3,
      "type": "书",
      "content": "裴秀,謹按見《文章敘錄》。《魏志·裴潛傳》注。",
      "work_id": "1evfubmtacnpc"
    },
    {
      "title": "聲無哀樂論",
      "level": 3,
      "type": "书",
      "content": "康,謹按見本書康傳。",
      "work_id": "1evfubmw5zg1s"
    }
  ]
