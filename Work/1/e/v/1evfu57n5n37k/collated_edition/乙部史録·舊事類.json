      "title": "乙部史録·舊事類",
      "level": 2,
      "type": "结语",
      "content": "右舊事類,存七家,失名十五家,二十四部。"
    },
    {
      "title": "晋太始太康故事五卷",
      "level": 3,
      "type": "书",
      "content": "謹按見兩《唐志》。",
      "work_id": "1evfuujpvxfr4"
    },
    {
      "title": "永平故事一卷",
      "level": 3,
