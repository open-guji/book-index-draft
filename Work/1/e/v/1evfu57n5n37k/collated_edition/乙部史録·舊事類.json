      "work_id": "1evfuujrwchs0"
    },
    {
      "title": "晋建武以來故事三卷",
      "level": 3,
      "type": "书",
      "content": "謹按見《隋志》。《新唐志》亦著録,而省“以來”二字。",
      "work_id": "1evfuujt3f8qo"
    },
    {
      "title": "咸和咸康故事四卷",
      "level": 3,
      "type": "书",
      "content": "孔愉,謹按見《隋志》。兩《唐志》作“建武和咸康故事”。是書《册府元龜》作“孔預撰”,又云預一名喻,皆 文也。",
      "work_id": "1evgphm9laeio"
    },
    {
      "title": "修復山陵故事五卷",
      "level": 3,
      "type": "书",
      "content": "車灌,謹按見《隋志》。",
      "work_id": "1evcml2fzb8xs"
    },
    {
      "title": "交州雜事九卷",
      "level": 3,
      "type": "书",
      "content": "謹按見《隋志》。舊注云:“記士變及陶 事。”兩《唐志》作“交州雜故事”,脱夾注。",
      "work_id": "1evcml2g4b1mo"
    },
    {
      "title": "四王起事四卷",
      "level": 3,
      "type": "书",
      "content": "廷尉盧琳。謹按見《隋志》。《舊唐志》“四王起居”。",
      "work_id": "1evcpcxhcer5s"
    },
    {
      "title": "八王故事十卷",
      "level": 3,
      "type": "书",
      "content": "盧琳。謹按見兩《唐志》。《隋志》亦著録,而脱撰人名。《册府元》作“十二卷”。",
      "work_id": "1evgphmc0oum8"
    },
    {
      "title": "東關故事",
      "level": 3,
      "type": "书",
      "content": "謹按見本書《禮志》。",
      "work_id": "1evfuujzzkwlc"
    },
    {
      "title": "大司馬陶公故事三卷",
      "level": 3,
